{
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug",
            "cargo": {
                "args": [
                    "run",
                    "--bin=packer"
                ],
                "filter": {
                    "name": "packer",
                    "kind": "bin"
                }
            },
            "args": [
                "--path",
                "test.exe"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "Build Packer"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Run (Debug)",
            "cargo": {
                "args": [
                    "run",
                    "--bin=packer"
                ],
                "filter": {
                    "name": "packer",
                    "kind": "bin"
                }
            },
            "args": [
                "--path",
                "test.exe"
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Packer"
        },
                {
            "type": "lldb",
            "request": "launch",
            "name": "Run (Release)",
            "cargo": {
                "args": [
                    "run",
                    "--bin=packer",
                    "--release"
                ],
                "filter": {
                    "name": "packer",
                    "kind": "bin"
                }
            },
            "args": [
                "--path",
                "test.exe"
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Packer (Release)"
        }
    ]
}